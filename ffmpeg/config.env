# FFmpeg defaults; override in /app/config.env or Docker env
VIDEO_CODEC=libx264
PRESET=veryfast
TUNE=zerolatency
PIX_FMT=yuv420p
PROFILE=high
LEVEL=4.2
GOP=120
KEYINT_MIN=120
BITRATE=6000k
MAXRATE=6000k
BUFSIZE=3000k
AUDIO_CODEC=aac
AUDIO_BITRATE=192k
AUDIO_RATE=48000
OFFLINE_FILE=/app/offline.mp4
